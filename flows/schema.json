{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BowPress Flow",
  "description": "Behavioral spec for one user-visible flow, executed identically on iOS XCUITest and Android Compose UI Test.",
  "type": "object",
  "required": ["name", "description", "runModes", "steps"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "snake_case identifier; matches filename without .flow.json suffix"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "enum": ["live", "draft"],
      "default": "live",
      "description": "live flows are runnable today; draft flows are spec-only and exempt from tag validation."
    },
    "runModes": {
      "type": "array",
      "items": { "enum": ["mock", "live"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "fixtures": {
      "type": "object",
      "description": "Map of 'METHOD /path' to fixture file path (relative to flows/). Mock-mode only.",
      "additionalProperties": { "type": "string" }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoSignInEmail": { "type": "string" },
        "autoSignInPassword": { "type": "string" },
        "startTab": { "type": "integer", "minimum": 0, "maximum": 4 },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/step" }
    }
  },
  "definitions": {
    "step": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "launch" },
            "env": { "type": "object", "additionalProperties": { "type": "string" } }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tag"],
          "properties": {
            "type": { "const": "tap" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "label"],
          "properties": {
            "type": { "const": "tapTab" },
            "label": { "enum": ["Home", "Analytics", "Log", "Session", "Equipment", "Settings"] }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tag", "text"],
          "properties": {
            "type": { "const": "type" },
            "tag": { "type": "string" },
            "text": { "type": "string" },
            "clearFirst": { "type": "boolean", "default": false }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tag", "direction"],
          "properties": {
            "type": { "const": "swipe" },
            "tag": { "type": "string" },
            "direction": { "enum": ["up", "down", "left", "right"] },
            "distance": { "type": "number", "default": 0.5 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tag"],
          "properties": {
            "type": { "const": "wait" },
            "tag": { "type": "string" },
            "timeout": { "type": "number", "default": 5 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tag"],
          "properties": {
            "type": { "const": "waitGone" },
            "tag": { "type": "string" },
            "timeout": { "type": "number", "default": 5 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tag", "text"],
          "properties": {
            "type": { "const": "assertText" },
            "tag": { "type": "string" },
            "text": { "type": "string" },
            "match": { "enum": ["equals", "contains"], "default": "equals" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "route"],
          "properties": {
            "type": { "const": "assertScreen" },
            "route": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tag"],
          "properties": {
            "type": { "const": "assertExists" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "tag"],
          "properties": {
            "type": { "const": "assertAbsent" },
            "tag": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "method", "path"],
          "properties": {
            "type": { "const": "apiExpect" },
            "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
            "path": { "type": "string" },
            "bodyContains": { "type": "object" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "method", "path", "status"],
          "properties": {
            "type": { "const": "apiRespond" },
            "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
            "path": { "type": "string" },
            "status": { "type": "integer", "minimum": 100, "maximum": 599 },
            "body": {},
            "bodyFile": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "method", "path", "body"],
          "properties": {
            "type": { "const": "serverPatch" },
            "method": { "enum": ["POST", "PATCH", "PUT", "DELETE"] },
            "path": { "type": "string" },
            "body": { "type": "object" }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
