{
  "name": "settings_change_password",
  "description": "User changes password from Settings → Change Password. POST /auth/change-password fires; success state is shown.",
  "runModes": ["mock"],
  "fixtures": {
    "GET /me": "fixtures/user_authed.json",
    "GET /subscription": "fixtures/entitlement_active.json"
  },
  "launch": { "autoSignInEmail": "e2e@bowpress.dev" },
  "steps": [
    { "type": "waitGone", "tag": "hydration_splash", "timeout": 20 },
    { "type": "tapTab", "label": "Settings" },
    { "type": "wait", "tag": "settings_change_password", "timeout": 5 },
    { "type": "tap", "tag": "settings_change_password" },
    { "type": "wait", "tag": "change_password_current", "timeout": 5 },
    { "type": "type", "tag": "change_password_current", "text": "old-password-1234" },
    { "type": "type", "tag": "change_password_new", "text": "new-password-5678" },
    { "type": "type", "tag": "change_password_confirm", "text": "new-password-5678" },
    { "type": "apiRespond", "method": "POST", "path": "/auth/change-password", "status": 204 },
    { "type": "tap", "tag": "change_password_submit" },
    { "type": "apiExpect", "method": "POST", "path": "/auth/change-password" }
  ]
}
