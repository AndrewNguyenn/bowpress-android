{
  "name": "paywall_lapsed_recovers",
  "description": "Lapsed (revoked) entitlement is forced inactive on the backend; banner reappears on cold launch; user re-purchases monthly; banner clears. Mirror of PaywallUITests.testLapsedSubscriptionRecovers.",
  "runModes": ["live"],
  "launch": {
    "autoSignInEmail": "e2e-free@bowpress.dev",
    "autoSignInPassword": "bowpress-e2e-pw-1234",
    "env": {
      "REAL_ENTITLEMENT": "1",
      "USE_LOCAL_API": "1"
    }
  },
  "steps": [
    {
      "type": "serverPatch",
      "method": "PATCH",
      "path": "/__test__/entitlement",
      "body": { "email": "e2e-free@bowpress.dev", "isActive": false }
    },
    { "type": "waitGone", "tag": "hydration_splash", "timeout": 20 },
    { "type": "wait", "tag": "main_tab_bar", "timeout": 5 },
    { "type": "wait", "tag": "upgrade_banner", "timeout": 10 },
    { "type": "tap", "tag": "upgrade_banner" },
    { "type": "wait", "tag": "paywall_monthly_button", "timeout": 15 },
    { "type": "tap", "tag": "paywall_monthly_button" },
    { "type": "waitGone", "tag": "upgrade_banner", "timeout": 15 }
  ]
}
