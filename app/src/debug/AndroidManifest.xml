<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only manifest overlay. Wires the debug build to the cleartext-
  permitted network_security_config so the emulator can talk to a local
  `wrangler dev` API over http://10.0.2.2:8787. The main manifest does
  not declare these attributes, so release builds keep the platform
  default (cleartext blocked).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        tools:replace="android:networkSecurityConfig,android:usesCleartextTraffic" />

</manifest>
