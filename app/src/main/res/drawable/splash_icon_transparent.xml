<?xml version="1.0" encoding="utf-8"?>
<!--
  Fully transparent 108×108 vector. Used as windowSplashScreenAnimatedIcon
  so the system splash on Android 12+ paints just the AppPaper background,
  with no launcher-icon flash before our composable HydrationSplashScreen
  mounts. Without an explicit icon, the SplashScreen API falls back to the
  app's launcher icon — which is what produced the "weird initial splash."
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:fillColor="#00000000" />
</vector>
