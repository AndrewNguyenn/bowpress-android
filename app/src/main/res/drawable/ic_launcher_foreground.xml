<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground — mirrors the iOS AppIcon mark so launcher
  visual parity holds between platforms.

  iOS AppIcon design (deep pond ground + World-Archery target face):
    • 4 concentric hairline ring outlines in pond-lt
    • Large yellow disc covering the inner 25% of the canvas
    • Thin hairline rim around the yellow disc, in the pond-dk ground color
    • Maple bullseye dot at center

  Authored in the standard 108×108 adaptive viewport. The actual mark is
  centered at (54, 54) and sized so the outermost ring sits just inside
  the 72×72 safe zone — values past r=36 may get clipped under non-circle
  masks, but the centre geometry (yellow disc + dot) reads identically
  across all mask shapes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 4 concentric hairline rings — pond-lt stroke against pond-dk bg. -->
    <path
        android:pathData="M54,18 a36,36 0 1,0 0,72 a36,36 0 1,0 0,-72 Z"
        android:strokeColor="#8FB3BF"
        android:strokeWidth="0.8"
        android:fillColor="#00000000" />
    <path
        android:pathData="M54,25 a29,29 0 1,0 0,58 a29,29 0 1,0 0,-58 Z"
        android:strokeColor="#8FB3BF"
        android:strokeWidth="0.8"
        android:fillColor="#00000000" />
    <path
        android:pathData="M54,32 a22,22 0 1,0 0,44 a22,22 0 1,0 0,-44 Z"
        android:strokeColor="#8FB3BF"
        android:strokeWidth="0.8"
        android:fillColor="#00000000" />
    <path
        android:pathData="M54,39 a15,15 0 1,0 0,30 a15,15 0 1,0 0,-30 Z"
        android:strokeColor="#8FB3BF"
        android:strokeWidth="0.8"
        android:fillColor="#00000000" />

    <!-- Yellow disc — target gold inner. -->
    <path
        android:pathData="M54,41 a13,13 0 1,0 0,26 a13,13 0 1,0 0,-26 Z"
        android:fillColor="#F0D04A" />

    <!-- Pond-dk hairline rim around the yellow disc. -->
    <path
        android:pathData="M54,41 a13,13 0 1,0 0,26 a13,13 0 1,0 0,-26 Z"
        android:strokeColor="#2D5A6B"
        android:strokeWidth="0.6"
        android:fillColor="#00000000" />

    <!-- Maple bullseye dot. -->
    <path
        android:pathData="M54,54 m-1.8,0 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0 Z"
        android:fillColor="#B5614A" />
</vector>
