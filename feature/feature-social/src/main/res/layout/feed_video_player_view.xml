<?xml version="1.0" encoding="utf-8"?><!--
    Inflated by FeedVideoTile so PlayerView uses TextureView for its
    rendering surface instead of the default SurfaceView. SurfaceView
    draws to its own window outside the Compose / View clip tree, so
    PlayerView's `RESIZE_MODE_ZOOM` (which grows the inner
    AspectRatioFrameLayout beyond PlayerView's bounds to center-crop)
    bleeds the surface past the feed card's 300dp stage. TextureView
    is a regular View whose drawing is clipped by its parent like any
    other child — keeps the aspect-fill crop without the overflow.
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:resize_mode="zoom"
    app:shutter_background_color="@android:color/black" />
